# .env.example
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# AdMob — obtain from Google AdMob console (https://admob.google.com)
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# IAP — no keys needed at runtime; product IDs are configured in
# the App Store Connect / Google Play Console and referenced in code
# as plain strings (e.g. 'com.sleepflow.premium_monthly')
